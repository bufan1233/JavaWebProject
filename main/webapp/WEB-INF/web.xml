<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!-- ==================== Filter 声明（按声明顺序执行） ==================== -->

    <!-- 1. EncodingFilter：最先执行，设置编码并在 finally 块归还数据库连接 -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.arctic.equipment.filter.EncodingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 2. RateLimitFilter：令牌桶限流，在登录校验前拦截恶意流量（429 Too Many Requests） -->
    <filter>
        <filter-name>RateLimitFilter</filter-name>
        <filter-class>com.arctic.equipment.filter.RateLimitFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>RateLimitFilter</filter-name>
        <url-pattern>/order/*</url-pattern>
    </filter-mapping>

    <!-- 3. LoginFilter：登录校验，验证 Session 中的 LOGIN_USER -->
    <filter>
        <filter-name>LoginFilter</filter-name>
        <filter-class>com.arctic.equipment.filter.LoginFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>LoginFilter</filter-name>
        <url-pattern>/order/*</url-pattern>
    </filter-mapping>

    <!-- 4. AdminFilter：管理员权限校验，验证用户角色是否为 ADMIN -->
    <filter>
        <filter-name>AdminFilter</filter-name>
        <filter-class>com.arctic.equipment.filter.AdminFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- ==================== 欢迎页 ==================== -->
    <welcome-file-list>
        <welcome-file>index</welcome-file>
    </welcome-file-list>

</web-app>